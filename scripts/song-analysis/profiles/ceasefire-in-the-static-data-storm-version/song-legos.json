        "gender": "female",
        "group": null,
        "spoken": null,
        "descriptor": "Soft"
      },
      "raw": "Female Vocal - Soft",
      "text": "I woke up under flashing skies\na thousand little mouths of light\nThey call my name, they sell me dreams\nthey follow me into the night",
      "lines": 4,
      "startT": 78.64,
      "endT": 86.16,
