        "gender": "female",
        "group": null,
        "spoken": null,
        "descriptor": "Female Lead"
      },
      "raw": "Pre-Chorus - Female Lead",
      "text": "昔はわざと\n火をつけて泣いてた\n喉が切れるくらい\nひどいことも言った\nでも tonight\nもう戻れない\n君を愛してるなら\nI can’t be your fire",
      "lines": 8,
      "startT": null,
      "endT": 277.76,
      "bars": null
    },
