      },
      "raw": "Post-Chorus - Male Ghost Vocal Behind Her",
      "text": "Don’t leave me alone\nDon’t leave me alone\nDon’t leave me alone\nwith my head like this",
      "lines": 4,
      "startT": 121.6,
      "endT": 132.47,
      "bars": 4
    },
    {
      "i": 8,
      "id": "i-won-t-be-your-fire::verse-2::8",
      "kind": "verse",
      "ordinal": 2,
      "voice": {
        "gender": "male",
        "group": null,
        "spoken": null,
        "descriptor": "Male Ghost Vocal, Fragile Melodic Rap"
      },
      "raw": "Verse 2 - Male Ghost Vocal, Fragile Melodic Rap",
      "text": "I keep your name in my phone\nlike a bruise I can press\nblack hoodie, dead screen\nbad dreams in my chest\nI don’t want peace\nI don’t know what that means\nI only feel close\nwhen you’re angry at me\nI been chasing the crash\ncause the calm feels fake\nI been calling it love\nwhen it’s only escape\nSay something cold\nmake it sound like you care\nI can’t stand the dark\nwhen there’s nobody there",
      "lines": 16,
      "startT": 132.47,
      "endT": 155.36,
      "bars": 8
    },
    {
      "i": 9,
      "id": "i-won-t-be-your-fire::spoken::9",
